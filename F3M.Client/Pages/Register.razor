@page "/register"
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>F3M - Register</PageTitle>

<div class="f3m-auth-page">
    <div class="f3m-auth-card">
        <div class="f3m-auth-logo">
            <span class="f3m-logo-badge" style="width:48px;height:48px;font-size:1.1rem;">F3M</span>
        </div>
        <h2 class="fw-black text-center mb-1">Create account</h2>
        <p class="text-center small mb-4">Join the Manaka modding community</p>

        @if (error is not null)
        {
            <div class="alert alert-danger py-2 small mb-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@error
            </div>
        }

        <EditForm Model="dto" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label fw-semibold small">Username</label>
                <InputText class="form-control f3m-input" placeholder="Choose a username"
                           @bind-Value="dto.Username" />
                <ValidationMessage For="@(() => dto.Username)" class="text-danger small mt-1 d-block" />
            </div>
            <div class="mb-3">
                @* // TODO: Remove this label*@
                <label class="form-label fw-semibold small text-warning">E-Mail dosen't do anything right now, feel free to enter garbage.</label> 
                <label class="form-label fw-semibold small">Email</label> 
                <InputText class="form-control f3m-input" type="email" placeholder="your@email.com"
                           @bind-Value="dto.Email" />
                <ValidationMessage For="@(() => dto.Email)" class="text-danger small mt-1 d-block" />
            </div>
            <div class="mb-3">
                @* // TODO: Remove this label*@
                <label class="form-label fw-semibold small text-danger">PW HASING IS MEH RIGHT NOW. DO NOT USE RE-USE YOUR PASSWORDS (you never should).</label>
                <label class="form-label fw-semibold small">Password</label>
                <InputText class="form-control f3m-input" type="password" placeholder="At least 8 characters"
                           @bind-Value="dto.Password" />
                <ValidationMessage For="@(() => dto.Password)" class="text-danger small mt-1 d-block" />
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold small">Confirm Password</label>
                <InputText class="form-control f3m-input" type="password" placeholder="Repeat your password"
                           @bind-Value="dto.ConfirmPassword" />
                <ValidationMessage For="@(() => dto.ConfirmPassword)" class="text-danger small mt-1 d-block" />
            </div>
            <button type="submit" class="btn btn-warning fw-bold w-100" disabled="@loading">
                @if (loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Create Account
            </button>
        </EditForm>
        <p class="text-center small mt-4 mb-0">
            Already have an account? <a href="/login" class="text-warning fw-semibold">Sign In</a>
        </p>
    </div>
</div>



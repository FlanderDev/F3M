@page "/mod/{Id:int}/edit"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>F3M - EditMod</PageTitle>

<div class="container py-5" style="max-width:680px;">

    @if (loading)
    {
        <div class="placeholder-glow">
            <div class="placeholder col-5 mb-3" style="height:2rem;border-radius:6px;"></div>
            <div class="placeholder col-12 mb-2" style="height:1rem;border-radius:4px;"></div>
        </div>
    }
    else if (forbidden)
    {
        <div class="text-center py-5">
            <h3 class="text-warning fw-bold">Access denied</h3>
            <p class="small">You don't have permission to edit this mod.</p>
            <a href="/" class="btn btn-outline-warning mt-2">Back to Browse</a>
        </div>
    }
    else if (mod is null)
    {
        <div class="text-center py-5">
            <h3 class="text-warning fw-bold">Mod not found</h3>
            <a href="/" class="btn btn-outline-warning mt-2">Back to Browse</a>
        </div>
    }
    else
    {
        <div class="mb-4">
            <a href="/mod/@Id" class="small d-inline-flex align-items-center gap-1 mb-3">
                <i class="bi bi-arrow-left"></i> Back to mod
            </a>
            <h1 class="fw-black mb-1 fs-2">Edit Mod</h1>
            <p class="small mb-0">
                Editing <span class="text-warning fw-semibold">@mod.Name</span>
                &nbsp;·&nbsp; v@mod.Version
            </p>
        </div>

        @if (saved)
        {
            <div class="alert alert-success mb-4">
                <i class="bi bi-check-circle-fill me-2"></i>Changes saved successfully.
            </div>
        }

        <div class="f3m-surface rounded-3 p-4 border" style="border-color:var(--f3m-border);">
            <EditForm Model="dto" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Mod Name <span class="text-danger">*</span></label>
                    <InputText class="form-control f3m-input" @bind-Value="dto.Name" />
                    <ValidationMessage For="@(() => dto.Name)" class="text-danger small mt-1 d-block" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-4">
                        <label class="form-label fw-semibold small">Version</label>
                        <InputText class="form-control f3m-input" placeholder="1.0.0" @bind-Value="dto.Version" />
                    </div>
                    <div class="col-8">
                        <label class="form-label fw-semibold small">Category</label>
                        <InputSelect class="form-select f3m-select" @bind-Value="dto.Category">
                            @foreach (var cat in Categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold small">Description</label>
                    <InputTextArea class="form-control f3m-input" rows="4" @bind-Value="dto.Description" />
                    <div  style="font-size:.72rem;">@(dto.Description?.Length ?? 0)/1000</div>
                </div>

                @if (saveError is not null)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@saveError
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold flex-grow-1" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-floppy me-2"></i>
                        }
                        @(saving ? "Saving…" : "Save Changes")
                    </button>
                    <a href="/mod/@Id" class="btn btn-outline-secondary fw-semibold px-4">Cancel</a>
                </div>
            </EditForm>
        </div>

        <!-- File list (read-only display; new files are added via Upload New Version) -->
        @if (mod.Files.Count > 0)
        {
            <div class="f3m-surface rounded-3 p-4 border mt-3" style="border-color:var(--f3m-border);">
                <h6 class="fw-bold mb-3">
                    <i class="bi bi-files me-2 text-warning"></i>Files in this version
                    <span class="fw-normal small ms-1">(to change files, upload a new version)</span>
                </h6>
                <div class="d-flex flex-column gap-2">
                    @foreach (var file in mod.Files)
                    {
                        <div class="f3m-file-entry">
                            <div class="f3m-file-entry-top">
                                <i class="bi bi-file-zip-fill text-warning fs-5 flex-shrink-0"></i>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold small text-truncate">@file.OriginalName</div>
                                    <div  style="font-size:.7rem;">@file.FileSizeDisplay</div>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(file.InstallPath))
                            {
                                <div class="f3m-file-entry-path">
                                    <i class="bi bi-folder2 flex-shrink-0" style="font-size:.8rem;"></i>
                                    <span class="f3m-path-input" style="cursor:default;">@file.InstallPath</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>



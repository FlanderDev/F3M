@page "/"
@inject HttpClient Http

<PageTitle>F3M — Mod Manager</PageTitle>

<!-- Header bar -->
<div class="f3m-page-header">
    <div class="container-fluid px-4 py-4">
        <div class="row align-items-center g-3">
            <div class="col">
                <h1 class="fw-black mb-0 fs-3">Browse Mods</h1>
                <p class="text-muted small mb-0">@(result?.TotalCount ?? 0) mods available</p>
            </div>
            <div class="col-auto">
                <AuthorizeView>
                    <Authorized>
                        <a href="/upload" class="btn btn-warning fw-bold px-4">
                            <i class="bi bi-cloud-arrow-up me-2"></i>Upload Mod
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-outline-warning fw-bold px-4">
                            <i class="bi bi-cloud-arrow-up me-2"></i>Upload Mod
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <!-- Filters -->
        <div class="row g-2 mt-3">
            <div class="col-12 col-md-5">
                <div class="input-group">
                    <span class="input-group-text f3m-search-icon">
                        <i class="bi bi-search"></i>
                    </span>
                    <input class="form-control f3m-search-input"
                           type="search"
                           placeholder="Search mods, authors…"
                           @bind="searchTerm"
                           @bind:event="oninput"
                           @onkeyup="OnSearchKeyUp" />
                </div>
            </div>
            <div class="col-6 col-md-3">
                <select class="form-select f3m-select" @bind="selectedCategory" @bind:after="LoadMods">
                    <option value="All">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-3">
                <select class="form-select f3m-select" @bind="sortBy" @bind:after="LoadMods">
                    <option value="newest">Newest</option>
                    <option value="popular">Most Downloaded</option>
                    <option value="name">Name A–Z</option>
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary" @onclick="ClearFilters" title="Clear filters">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <!-- Category chips -->
        @if (categories.Any())
        {
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button class="f3m-chip @(selectedCategory == "All" ? "active" : "")"
                        @onclick='() => SelectCategory("All")'>All</button>
                @foreach (var cat in categories)
                {
                    <button class="f3m-chip @(selectedCategory == cat ? "active" : "")"
                            @onclick="() => SelectCategory(cat)">@cat</button>
                }
            </div>
        }
    </div>
</div>

<!-- Mod grid -->
<div class="container-fluid px-4 py-4">
    @if (loading)
    {
        <div class="mod-grid">
            @for (int i = 0; i < 12; i++)
            {
                <div class="mod-card-skeleton">
                    <div class="skeleton-img"></div>
                    <div class="skeleton-body">
                        <div class="skeleton-line w-75"></div>
                        <div class="skeleton-line w-50 mt-1"></div>
                        <div class="skeleton-line w-full mt-2"></div>
                        <div class="skeleton-line w-90"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (result?.Items.Count == 0)
    {
        <div class="f3m-empty text-center py-5">
            <i class="bi bi-inbox display-3 text-muted opacity-50 d-block mb-3"></i>
            <h5 class="fw-bold mb-1">No mods found</h5>
            <p class="text-muted small">Try adjusting your filters.</p>
            <button class="btn btn-sm btn-outline-warning mt-2" @onclick="ClearFilters">Clear Filters</button>
        </div>
    }
    else
    {
        <div class="mod-grid">
            @foreach (var mod in result!.Items)
            {
                <ModCard Mod="mod" />
            }
        </div>

        <!-- Pagination -->
        @if (result.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-5">
                <ul class="pagination f3m-pagination gap-1 mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @for (int p = 1; p <= result.TotalPages; p++)
                    {
                        var pg = p;
                        <li class="page-item @(pg == currentPage ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == result.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </div>
        }
    }
</div>

@code {
    private ModListResult? result;
    private List<string> categories = [];
    private bool loading = true;
    private string searchTerm = "";
    private string selectedCategory = "All";
    private string sortBy = "newest";
    private int currentPage = 1;
    private const int pageSize = 18;
    private System.Timers.Timer? _debounce;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadMods();
    }

    private async Task LoadCategories()
        => categories = await Http.GetFromJsonAsync<List<string>>("api/mods/categories") ?? [];

    private async Task LoadMods()
    {
        loading = true;
        StateHasChanged();
        try
        {
            var url = $"api/mods?page={currentPage}&pageSize={pageSize}" +
                      $"&search={Uri.EscapeDataString(searchTerm)}" +
                      $"&category={Uri.EscapeDataString(selectedCategory)}&sort={sortBy}";
            result = await Http.GetFromJsonAsync<ModListResult>(url);
        }
        catch { result = new ModListResult(); }
        finally { loading = false; }
    }

    private void OnSearchKeyUp(KeyboardEventArgs _)
    {
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(350);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            currentPage = 1;
            await InvokeAsync(LoadMods);
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task SelectCategory(string cat) { selectedCategory = cat; currentPage = 1; await LoadMods(); }
    private async Task GoToPage(int p) { currentPage = p; await LoadMods(); }
    private async Task ClearFilters() { searchTerm = ""; selectedCategory = "All"; sortBy = "newest"; currentPage = 1; await LoadMods(); }
}
